rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function validShareClip(clip) {
      return clip.keys().hasOnly([
        'kind',
        'text',
        'imageData',
        'title',
        'folder',
        'tags',
        'digest',
        'pinned',
        'createdAt'
      ])
      && clip.kind in ['text', 'image']
      && clip.text is string
      && clip.text.size() <= 100000
      && clip.imageData is string
      && clip.imageData.size() <= 950000
      && clip.title is string
      && clip.title.size() <= 140
      && clip.folder is string
      && clip.folder.size() <= 80
      && clip.tags is list
      && clip.tags.size() <= 8
      && clip.digest is string
      && clip.digest.size() <= 128
      && clip.pinned is bool
      && clip.createdAt is string;
    }

    function validShareWrite(code) {
      return request.resource.data.keys().hasOnly(['code', 'clips', 'createdAt', 'expiresAt'])
      && code.matches('^[0-9]{6}$')
      && request.resource.data.code == code
      && request.resource.data.clips is list
      && request.resource.data.clips.size() >= 1
      && request.resource.data.clips.size() <= 20
      && request.resource.data.createdAt is timestamp
      && request.resource.data.expiresAt is timestamp
      && request.resource.data.expiresAt > request.time
      && request.resource.data.expiresAt <= request.time + duration.value(1, 'h')
      && validShareClip(request.resource.data.clips[0]);
    }

    match /users/{userId}/clips/{clipId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /publicShares/{code} {
      allow get: if !exists(/databases/$(database)/documents/publicShares/$(code))
        || (resource.data.expiresAt is timestamp && resource.data.expiresAt > request.time);
      allow list: if false;
      allow create: if validShareWrite(code);
      allow update: if resource.data.expiresAt is timestamp
        && resource.data.expiresAt <= request.time
        && validShareWrite(code);
      allow delete: if false;
    }
  }
}
